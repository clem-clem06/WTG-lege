{% extends 'base.html.twig' %}

{% block title %}Accueil - WorkTogether Data Solutions{% endblock %}

{% block body %}
    <div class="container py-5">

        <header class="text-center mb-5">
            <h1 class="display-4 fw-bold">Bienvenue chez WorkTogether Data Solutions</h1>
            <p class="lead text-muted">Hébergez vos infrastructures dans nos datacenters hautement sécurisés.</p>
        </header>

        <h2 class="text-center mb-4">Nos offres de location de baies</h2>

        <div class="row justify-content-center g-4">
            {% for offre in offres %}
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="card h-100 shadow-sm text-center border-primary">
                        <div class="card-header bg-primary text-white py-3">
                            <h3 class="my-0 fw-normal fs-4">{{ offre.nom }}</h3>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title pricing-card-title fs-2">
                                {{ (offre.prixMensuel / 100)|number_format(2, ',', ' ') }} €<small class="text-muted fw-light fs-6"> / mois</small>
                            </h4>
                            <p class="text-muted small mb-4">
                                Soit {{ (offre.prixAnnuel / 100)|number_format(2, ',', ' ') }} € par an
                            </p>

                            <ul class="list-unstyled mt-3 mb-4">
                                {% if offre.nombreUnites > 1 %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unités incluses</li>
                                {% else %}
                                    <li><strong>{{ offre.nombreUnites }}</strong> Unité incluse</li>
                                {% endif %}
                            </ul>

                            <a href="#" class="btn btn-lg btn-outline-primary mt-auto w-100">Choisir cette offre</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center">
                    <p class="alert alert-info">Aucune offre disponible pour le moment.</p>
                </div>
            {% endfor %}
        </div>

    </div>
{% endblock %}
